---
import Base from '../layouts/Base.astro';
import { SITE } from '../config.ts';
---

<Base title="お問い合わせ" path="/contact">
  <section class="hero" style="padding-bottom:6px;">
    <h1>お問い合わせ</h1>
  </section>

  <div class="prose">
    <p>当サイトおよび各プロジェクトに関するご意見・ご要望・お問い合わせは、以下までご連絡ください。</p>
    {SITE.contactEmail ? (
      <p style="font-size:1.1rem;">📧 <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a></p>
    ) : (
      <p style="color:var(--ink-soft);">（お問い合わせ先は準備中です）</p>
    )}
  </div>
</Base>
